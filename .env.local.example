# ============================================================
# StaySecure360 Environment Variables
# Copy this file to .env.local and fill in your values.
# In Vercel, add these under Project > Settings > Environment Variables.
# ============================================================

# --- Supabase (REQUIRED) ---
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — server-side only, NEVER expose to client
# Found in: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- OpenAI (REQUIRED for AI article generation) ---
# Found in: https://platform.openai.com/api-keys
# This key is used server-side only via /api/generate-article
OPENAI_API_KEY=sk-...your-openai-key-here

# --- Google Analytics 4 (OPTIONAL but recommended for SEO monitoring)
# How to get it:
#   1. Go to https://analytics.google.com
#   2. Admin > Data Streams > your stream > Measurement ID (starts with G-)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- YouTube Data API v3 (REQUIRED for YouTube video search in admin) ---
# How to get it:
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or select an existing one)
#   3. Enable the "YouTube Data API v3" under APIs & Services > Library
#   4. Go to APIs & Services > Credentials > Create Credentials > API Key
#   5. Copy the key here
# This key is used server-side only via /api/youtube-search
YOUTUBE_API_KEY=your-youtube-api-key-here

# --- Site URL (REQUIRED for SEO canonical URLs) ---
NEXT_PUBLIC_SITE_URL=https://www.staysecure360.com
