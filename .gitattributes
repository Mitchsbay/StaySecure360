# Enforce LF line endings for all text files
* text=auto eol=lf

# Source files
*.tsx        text eol=lf
*.ts         text eol=lf
*.js         text eol=lf
*.mjs        text eol=lf
*.cjs        text eol=lf
*.jsx        text eol=lf

# Config & data files
*.json       text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.toml       text eol=lf
*.env        text eol=lf
*.env.*      text eol=lf

# Style files
*.css        text eol=lf
*.scss       text eol=lf

# SQL files
*.sql        text eol=lf

# Markup & docs
*.md         text eol=lf
*.mdx        text eol=lf
*.html       text eol=lf
*.xml        text eol=lf
*.txt        text eol=lf

# Shell scripts
*.sh         text eol=lf

# Binary files — do not modify line endings
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.svg        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.eot        binary
*.zip        binary
*.pdf        binary
